# =============================================================================
# SPECTRUM Database - deployment environment variables
# -----------------------------------------------------------------------------
# Copy to `.env` (in this folder) and fill in real values before running
# `docker-compose up`. Variables marked REQUIRED have no safe default and the
# stack will refuse to start without them.
#
# Targets Docker Engine 20.10+ with docker-compose v1.29+. To speed builds
# (optional), export BuildKit flags before `docker-compose build`:
#   export DOCKER_BUILDKIT=1
#   export COMPOSE_DOCKER_CLI_BUILD=1
# =============================================================================

# Compose project name. Replaces the v2-only top-level `name:` field.
COMPOSE_PROJECT_NAME=spectrumdb

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="SPECTRUM Database"
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# REQUIRED. Public hostname served by Caddy (TLS is provisioned for this name).
APP_DOMAIN=spectrum.example.org

# REQUIRED. Generate once with `php artisan key:generate --show` and keep it
# stable across deploys, otherwise existing sessions / encrypted columns break.
APP_KEY=

LOG_LEVEL=warning

# -----------------------------------------------------------------------------
# Reverse proxy / TLS
# -----------------------------------------------------------------------------
# REQUIRED. Used by Caddy to register with Let's Encrypt and receive expiry
# warnings.
ACME_EMAIL=ops@example.org

# Host ports for Caddy. Change only if you run behind another load balancer.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# MySQL
# -----------------------------------------------------------------------------
DB_DATABASE=spectrum
DB_USERNAME=spectrum
DB_PASSWORD=change-me-please
DB_ROOT_PASSWORD=change-me-too

# -----------------------------------------------------------------------------
# Redis (used for cache, queue and Reverb scaling)
# -----------------------------------------------------------------------------
# Leave as "null" to disable Redis auth (the redis container is not exposed to
# the host so this is acceptable). Set a real password if you publish the port.
REDIS_PASSWORD=null

# -----------------------------------------------------------------------------
# Laravel Reverb (Pusher protocol). Pick strong, unique values; the public
# REVERB_APP_KEY is shipped to browsers via Vite, the secret must NEVER be.
# -----------------------------------------------------------------------------
REVERB_APP_ID=spectrum
REVERB_APP_KEY=
REVERB_APP_SECRET=

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
SESSION_LIFETIME=120

# -----------------------------------------------------------------------------
# Mail (external SMTP). Leave the credentials empty during initial bring-up if
# you don't have an SMTP provider yet; outgoing mail will simply fail.
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=null
MAIL_FROM_ADDRESS=no-reply@spectrum.example.org
MAIL_FROM_NAME="SPECTRUM Database"

# -----------------------------------------------------------------------------
# S3 (optional). Leave empty to keep using the local filesystem disk.
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# -----------------------------------------------------------------------------
# Image tag used by the compose stack. Bump to roll out a new build.
# -----------------------------------------------------------------------------
IMAGE_TAG=latest
